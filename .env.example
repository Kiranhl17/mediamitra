# ─── MediaMitra — Environment Variables ──────────────────────────────────────
# Copy this to .env.local for local dev, or paste into Vercel dashboard
# NEVER commit .env.local to Git

# Your Gmail address
GMAIL_USER=mediamitra05@gmail.com

# Gmail App Password (NOT your real password)
# Get it from: https://myaccount.google.com/apppasswords
GMAIL_PASS=your_16_char_app_password_here

# Where leads get delivered (your inbox)
NOTIFY_EMAIL=mediamitra05@gmail.com

# Your live domain (no trailing slash)
ALLOWED_ORIGIN=https://your-site.vercel.app

NODE_ENV=production
